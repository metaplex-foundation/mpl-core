CARGO_TERM_COLOR=always
NODE_VERSION=20.x
PROGRAMS=["mpl-core"]
RUST_VERSION=1.88.0
SOLANA_VERSION=2.3.5
SOLANA_VERIFY_VERSION=0.4.15
# Verified-build toolchain version, resolved to a digest-pinned image by the
# verified-build / verify-program actions via solana-verify-base-images.json.
# Pinned to 3.1.14 (platform-tools v1.52), the newest official image; mpl-core's
# native tool is v1.53 but no official v1.53 image exists yet. Revisit when it does.
SOLANA_VERIFY_BUILD_VERSION=3.1.14
COMMIT_USER_NAME=github-actions
COMMIT_USER_EMAIL=github-actions@github.com
DEPLOY_SOLANA_VERSION=2.3.5
